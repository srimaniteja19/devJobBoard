{
  "manifest_version": 3,
  "name": "JobTracker — Save Jobs Instantly",
  "version": "1.0.0",
  "description": "Add jobs to your JobTracker from any job board with one click",

  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "notifications",
    "contextMenus"
  ],

  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.workday.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.jobvite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.rippling.com/*",
    "http://localhost:3000/*",
    "https://mani-job-tracker.vercel.app/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Save to JobTracker"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractors.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
