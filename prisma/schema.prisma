generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ─────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  image         String?
  password      String?        // hashed; null for OAuth users
  emailVerified DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  accounts     Account[]
  sessions     Session[]
  applications Application[]
  activities   ActivityLog[]
  jobSources   UserJobSource[]
  savedJobs      SavedJob[]
  quickApplyNotes QuickApplyNote[]
}

model QuickApplyNote {
  id        String   @id @default(cuid())
  userId    String
  label     String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserJobSource {
  id         String   @id @default(cuid())
  userId     String
  company    String
  source     String   // 'greenhouse' | 'ashby' | 'lever' | 'custom'
  boardToken String   // Board slug or full URL for custom
  careersUrl String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, boardToken])
  @@index([userId])
}

model SavedJob {
  id        String    @id @default(cuid())
  userId    String
  jobId     String    // Feed job id (e.g. gh-stripe-123)
  jobUrl    String
  title     String
  company   String
  location  String?
  source    String
  savedAt   DateTime  @default(now())
  appliedAt DateTime? // When user marked as applied

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Application {
  id                String    @id @default(cuid())
  userId            String
  company           String
  role              String
  jobUrl            String?
  salary            String?
  location          String?
  type              String    @default("REMOTE")
  stack             String    @default("[]")
  status            String    @default("WISHLIST")
  resumeLabel       String?
  resumeFileUrl     String?
  resumeFileName    String?
  resumeText        String?
  resumeUploadedAt  DateTime?
  appliedAt         DateTime?
  followUpDate      DateTime?
  notes             String?
  source            String    @default("manual") // 'manual' | 'extension' | 'import'
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  events      Event[]
  activities  ActivityLog[]
  preps             ApplicationPrep[]
  resumeMatch       ResumeMatch?
  generatedResumes  GeneratedResume[]
  chatMessages      ChatMessage[]
  statusHistory     ApplicationStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, followUpDate])
}

model ResumeMatch {
  id            String   @id @default(cuid())
  applicationId String   @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  overallScore  Int
  atsScore      Int
  result        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GeneratedResume {
  id             String   @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  htmlContent    String
  jsonContent    String
  changesSummary String
  version        Int      @default(1)
  createdAt      DateTime @default(now())

  @@index([applicationId])
}

model Contact {
  id            String  @id @default(cuid())
  applicationId String
  name          String
  role          String?
  email         String?
  linkedin      String?
  notes         String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Event {
  id            String   @id @default(cuid())
  applicationId String
  type          String   @default("OTHER")
  scheduledAt   DateTime
  notes         String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([scheduledAt])
}

model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  applicationId String
  action        String
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([applicationId])
}

model ApplicationPrep {
  id            String   @id @default(cuid())
  applicationId String
  stage         String
  sectionKey    String
  content       String
  generatedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, stage, sectionKey])
  @@index([applicationId])
  @@index([applicationId, stage])
}

model ChatMessage {
  id              String    @id @default(cuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  role            String    // 'user' | 'assistant'
  content         String    // message text (markdown supported)
  attachmentName  String?   // if user attached a file in this message
  attachmentText  String?   // extracted text from attachment
  feedback        String?   // 'positive' | 'negative' for thumbs up/down
  createdAt       DateTime  @default(now())

  @@index([applicationId])
  @@index([applicationId, createdAt])
}

model ApplicationStatusHistory {
  id            String   @id @default(cuid())
  applicationId String
  fromStatus    String?
  toStatus      String
  changedAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([applicationId, changedAt])
}
